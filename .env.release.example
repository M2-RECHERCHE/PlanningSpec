APP_ENV=release
APP_TAG=release
NODE_ENV=production

# Release runs on the deployment machine first. Replace by your domain later.
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
REACT_APP_API_BASE_URL=
FRONTEND_PORT_PUBLIC=8080
OPTAPLANNER_PORT_PUBLIC=8084
PHPMYADMIN_BIND=127.0.0.1
PHPMYADMIN_PORT_PUBLIC=8082
PHPMYADMIN_UPLOAD_LIMIT=256M

MYSQL_ROOT_PASSWORD=regent@2026
MYSQL_DATABASE=planning_spec
MYSQL_USER=planify
MYSQL_PASSWORD=regent@2026
MYSQL_CONNECTION_LIMIT=20

AUTH_SESSION_TTL_DAYS=90
AUTH_TOKEN_BYTES=32

MINIZINC_PATH=/usr/bin/minizinc
MINIZINC_DEFAULT_SOLVER=chuffed
MINIZINC_VERSION=2.9.7
MINIZINC_BUNDLE_SHA256=7e78d3a1d6feec2f5b6a43628632decb6995755ade92ff4e51a2188c54ca6399
MINIZINC_SOLVER_PACKAGES=""
REQUIRE_MINIZINC_SOLVERS="Gecode Chuffed HiGHS"
MINIZINC_WORKDIR=/var/lib/planify/minizinc
MINIZINC_ENABLE_TIMEOUT=false
MINIZINC_DEFAULT_TIME_LIMIT=0
SSE_HEARTBEAT_INTERVAL=15000

OPTAPLANNER_URL=http://planning-solver:8084
OPTAPLANNER_TIMEOUT_MS=0
OPTAPLANNER_JAVA_OPTS="-Xms512m -Xmx3g"

LOG_LEVEL=info
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=regent@2026

BACKEND_CPU_LIMIT=4
BACKEND_MEMORY_LIMIT=4g
BACKEND_MEMORY_RESERVATION=512m
FRONTEND_CPU_LIMIT=1
FRONTEND_MEMORY_LIMIT=512m
OPTAPLANNER_CPU_LIMIT=4
OPTAPLANNER_MEMORY_LIMIT=4g
OPTAPLANNER_MEMORY_RESERVATION=512m
