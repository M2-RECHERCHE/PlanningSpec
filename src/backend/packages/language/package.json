{
  "name": "planning-spec-language",
  "description": "Paquet Langium pour le DSL Planning Spec",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10.0.0"
  },
  "files": [
    "out",
    "src",
    "syntaxes",
    "langium-config.json"
  ],
  "main": "./out/index.js",
  "module": "./out/index.js",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js",
      "default": "./out/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "out/index"
      ]
    }
  },
  "scripts": {
    "clean": "shx rm -rf out *.tsbuildinfo",
    "build": "pnpm run langium:generate && tsc -b tsconfig.src.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "langium": "~4.2.0"
  },
  "devDependencies": {
    "langium-cli": "~4.2.0",
    "vitest": "~3.1.3"
  },
  "types": "./out/index.d.ts"
}
