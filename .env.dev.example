APP_ENV=dev
APP_TAG=dev
NODE_ENV=development

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
REACT_APP_API_BASE_URL=http://localhost:4000

FRONTEND_PORT_PUBLIC=3000
BACKEND_PORT_PUBLIC=4000
MYSQL_PORT_PUBLIC=3306
ADMINER_PORT_PUBLIC=8081
PHPMYADMIN_PORT_PUBLIC=8082
PHPMYADMIN_UPLOAD_LIMIT=256M
VAULT_PORT_PUBLIC=8200
OPTAPLANNER_PORT_PUBLIC=8084

MYSQL_ROOT_PASSWORD=dev-root-password-change-me
MYSQL_DATABASE=planning_spec
MYSQL_USER=planify
MYSQL_PASSWORD=dev-app-password-change-me
MYSQL_CONNECTION_LIMIT=10

AUTH_SESSION_TTL_DAYS=90
AUTH_TOKEN_BYTES=32

MINIZINC_PATH=/usr/bin/minizinc
MINIZINC_DEFAULT_SOLVER=chuffed
MINIZINC_VERSION=2.9.7
MINIZINC_BUNDLE_SHA256=7e78d3a1d6feec2f5b6a43628632decb6995755ade92ff4e51a2188c54ca6399
MINIZINC_SOLVER_PACKAGES=""
REQUIRE_MINIZINC_SOLVERS="Gecode Chuffed HiGHS"
MINIZINC_WORKDIR=/var/lib/planify/minizinc
MINIZINC_ENABLE_TIMEOUT=false
MINIZINC_DEFAULT_TIME_LIMIT=0
SSE_HEARTBEAT_INTERVAL=15000

OPTAPLANNER_URL=http://planning-solver:8084
OPTAPLANNER_TIMEOUT_MS=108000000
OPTAPLANNER_JAVA_OPTS="-Xms256m -Xmx2g"

LOG_LEVEL=debug
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token-change-me
