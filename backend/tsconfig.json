{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "lib": [
      "ES2020"
    ],
    "sourceMap": true,
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "planning-spec-language": [
        "./packages/language/out/index.d.ts"
      ],
      "planning-spec-language/*": [
        "./packages/language/out/*"
      ]
    }
  },
  "include": [
    "**/src/**/*",
    "**/test/**/*"
  ],
  "exclude": [
    "**/lib/**/*",
    "**/out/**/*",
    "**/dist/**/*",
    "**/node_modules/**/*"
  ]
}
